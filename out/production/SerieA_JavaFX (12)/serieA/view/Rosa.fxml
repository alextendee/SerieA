<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serieA.controller.RosaController"
            stylesheets="/serieA/view/theme.css"
            styleClass="root-bg">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="pad-vertical card">
            <Label fx:id="lblSquadra" text="Rosa"
                   style="-fx-font-size:20; -fx-font-weight:bold;" styleClass="accent-strong"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtRicerca" promptText="Cerca giocatore..."
                       prefWidth="250"
                       styleClass="input input-rounded"/>
        </HBox>

        <Label text="Clicca un giocatore per vedere i dettagli"
               styleClass="muted" style="-fx-font-size:11; -fx-padding:6 20 4 20;"/>

        <TableView fx:id="tabellaRosa" VBox.vgrow="ALWAYS" styleClass="table">
            <columns>
                <TableColumn fx:id="colNome"        text="Nome"        prefWidth="100"/>
                <TableColumn fx:id="colCognome"     text="Cognome"     prefWidth="130"/>
                <TableColumn fx:id="colNazionalita" text="Nazionalita" prefWidth="110"/>
                <TableColumn fx:id="colEta"         text="Eta"         prefWidth="55"/>
                <TableColumn fx:id="colAltezza"     text="Alt. (cm)"   prefWidth="80"/>
                <TableColumn fx:id="colGol"         text="Gol"         prefWidth="60"/>
                <TableColumn fx:id="colAssist"      text="Assist"      prefWidth="70"/>
                <TableColumn fx:id="colValore"      text="Valore"      prefWidth="100"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" styleClass="pad-vertical card">
            <Button text="Chiudi" onAction="#handleChiudi" styleClass="btn btn-strong" style="-fx-padding:8 20 8 20;"/>
        </HBox>
    </VBox>
</AnchorPane>
