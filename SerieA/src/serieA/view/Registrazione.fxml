<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="420.0" prefWidth="450.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serieA.controller.RegistrazioneController"
            stylesheets="/serieA/view/theme.css"
            styleClass="root-bg">

    <VBox alignment="CENTER" spacing="15.0"
          AnchorPane.topAnchor="30.0" AnchorPane.bottomAnchor="20.0"
          AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0">

        <Label text="REGISTRAZIONE" style="-fx-font-size:24; -fx-font-weight:bold;" styleClass="accent-strong"/>
        <Label text="Crea il tuo account utente" style="-fx-font-size:13;" styleClass="muted"/>

        <VBox spacing="5.0" maxWidth="300.0">
            <Label text="Username" styleClass="primary-text"/>
            <TextField fx:id="txtUsername" promptText="Scegli un username" styleClass="input"/>
        </VBox>

        <VBox spacing="5.0" maxWidth="300.0">
            <Label text="Password" styleClass="primary-text"/>
            <PasswordField fx:id="txtPassword" promptText="Scegli una password (min. 4 caratteri)" styleClass="input"/>
        </VBox>

        <VBox spacing="5.0" maxWidth="300.0">
            <Label text="Conferma Password" styleClass="primary-text"/>
            <PasswordField fx:id="txtConfermaPassword" promptText="Ripeti la password" styleClass="input"/>
        </VBox>

        <Label fx:id="lblErrore" text="" styleClass="error" style="-fx-font-size:12;"/>
        <Label fx:id="lblSuccesso" text="" styleClass="success" style="-fx-font-size:12;"/>

        <Button text="REGISTRATI" onAction="#handleRegistra"
                maxWidth="300.0"
                styleClass="btn btn-strong" style="-fx-font-size:14; -fx-padding:10 0 10 0;"/>

        <Button text="← Torna al Login" onAction="#handleTornaLogin"
                maxWidth="300.0"
                styleClass="btn-ghost" style="-fx-font-size:12; -fx-cursor:hand; -fx-border-color:#00a1e4; -fx-border-radius:6; -fx-background-radius:6; -fx-padding:6 0 6 0;"/>
    </VBox>
</AnchorPane>
