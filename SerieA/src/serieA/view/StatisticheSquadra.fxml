<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serieA.controller.StatisticheSquadraController"
            stylesheets="/serieA/view/theme.css"
            styleClass="root-bg">

    <VBox spacing="20" alignment="CENTER"
          AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="60" AnchorPane.rightAnchor="60">

        <Label fx:id="lblNome" text="Squadra"
               style="-fx-font-size:30; -fx-font-weight:bold;" styleClass="accent-strong"/>

        <!-- Stats cards -->
        <VBox spacing="12" styleClass="card">
            <Label text="Statistiche Stagione" styleClass="accent-strong" style="-fx-font-weight:bold; -fx-font-size:14;"/>
            <Label fx:id="lblPunti" text="" styleClass="primary-text" style="-fx-font-size:16; -fx-font-weight:bold;"/>
            <Label fx:id="lblRecord" text="" styleClass="muted" style="-fx-font-size:14;"/>
            <Label fx:id="lblGol" text="" styleClass="muted" style="-fx-font-size:14;"/>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="15" alignment="CENTER">
            <Button text="Rosa" onAction="#handleRosa"
                    prefWidth="150"
                    styleClass="btn btn-strong" style="-fx-font-size:13; -fx-padding:12;"/>
            <Button text="Storico Trasferimenti" onAction="#handleStoico"
                    prefWidth="200"
                    styleClass="btn" style="-fx-font-size:13; -fx-padding:12; -fx-background-color:#0f3460; -fx-border-color:#e94560; -fx-border-radius:8;"/>
            <Button fx:id="btnBilancio" text="Bilancio" onAction="#handleBilancio"
                    prefWidth="150"
                    styleClass="btn success" style="-fx-font-size:13; -fx-padding:12;"/>
        </HBox>

        <Button text="Chiudi" onAction="#handleChiudi" styleClass="btn-ghost" style="-fx-border-color:#555; -fx-border-radius:6; -fx-background-radius:6; -fx-padding:8 30 8 30;"/>
    </VBox>
</AnchorPane>
