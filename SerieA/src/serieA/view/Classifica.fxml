<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" styleClass="panel-bg" stylesheets="/serieA/view/theme.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="serieA.controller.ClassificaController">

    <VBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="pad-vertical card">
            <Label style="-fx-font-size:22; -fx-font-weight:bold;" styleClass="accent-strong" text="Seria A" />
            <Label style="-fx-font-size:18;" styleClass="primary-text" text="Classifica" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="lblUtente" style="-fx-font-size:13;" styleClass="primary-text" text="" />
                <Label fx:id="lblRuolo" style="-fx-font-size:11;" styleClass="accent-strong" text="" />
            </VBox>
            <Button onAction="#handleLogout" style="-fx-font-size:12; -fx-background-radius:6;" styleClass="btn btn-strong" text="Logout" />
        </HBox>

        <Label style="-fx-font-size:11; -fx-padding:8 20 4 20;" styleClass="muted" text="Clicca una squadra per vedere le statistiche" />

        <TableView fx:id="tabellaClassifica" styleClass="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNome" prefWidth="150" text="Squadra" />
                <TableColumn fx:id="colPunti" prefWidth="55" text="Pt" />
                <TableColumn fx:id="colPG" prefWidth="55" text="PG" />
                <TableColumn fx:id="colPV" prefWidth="55" text="V" />
                <TableColumn fx:id="colPP" prefWidth="55" text="P" />
                <TableColumn fx:id="colPL" prefWidth="55" text="S" />
                <TableColumn fx:id="colGF" prefWidth="70" text="GF" />
                <TableColumn fx:id="colGS" prefWidth="70" text="GS" />
            </columns>
        </TableView>
    </VBox>
</AnchorPane>
