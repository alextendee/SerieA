<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="550.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serieA.controller.DettaglioGiocatoreController"
            stylesheets="/serieA/view/theme.css"
            styleClass="root-bg">

    <VBox spacing="18" alignment="CENTER"
          AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="60" AnchorPane.rightAnchor="60">

        <Label text="Scheda Giocatore" styleClass="muted" style="-fx-font-size:14;"/>
        <Label fx:id="lblNomeCompleto" text="" style="-fx-font-size:28; -fx-font-weight:bold;" styleClass="accent-strong"/>
        <Label fx:id="lblSquadra" text="" styleClass="highlight" style="-fx-font-size:14;"/>

        <!-- Info grid -->
        <VBox spacing="10" styleClass="card">
            <Label text="Informazioni Personali"
                   styleClass="accent-strong" style="-fx-font-weight:bold; -fx-font-size:13;"/>
            <HBox spacing="40">
                <VBox spacing="8">
                     <Label fx:id="lblNazionalita" text="" styleClass="muted" style="-fx-font-size:13;"/>
                     <Label fx:id="lblEta" text="" styleClass="muted" style="-fx-font-size:13;"/>
                     <Label fx:id="lblAltezza" text="" styleClass="muted" style="-fx-font-size:13;"/>
                </VBox>
                <VBox spacing="8">
                     <Label fx:id="lblGol" text="" styleClass="muted" style="-fx-font-size:13;"/>
                     <Label fx:id="lblAssist" text="" styleClass="muted" style="-fx-font-size:13;"/>
                     <Label fx:id="lblValore" text="" styleClass="gold" style="-fx-font-size:14; -fx-font-weight:bold;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Admin buttons -->
        <HBox spacing="20" alignment="CENTER">
            <Button fx:id="btnCompra" text="COMPRA" onAction="#handleCompra"
                    prefWidth="160"
                    styleClass="btn success" style="-fx-font-size:14; -fx-padding:12;"/>
            <Button fx:id="btnVendi" text="VENDI" onAction="#handleVendi"
                    prefWidth="160"
                    styleClass="btn danger" style="-fx-font-size:14; -fx-padding:12;"/>
        </HBox>

        <Button text="Chiudi" onAction="#handleChiudi" styleClass="btn-ghost" style="-fx-border-color:#555; -fx-border-radius:6; -fx-background-radius:6; -fx-padding:8 30 8 30;"/>
    </VBox>
</AnchorPane>
